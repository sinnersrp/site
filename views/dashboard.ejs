<%- include("partials/header") %>

<section class="profile-box container">
  <img src="<%= user.avatar %>" alt="avatar" class="avatar">
  <div>
    <h1><%= user.globalName || user.username %></h1>
    <p>@<%= user.username %></p>
    <p>Cargo principal: <strong><%= user.role %></strong></p>
    <p>
      Cargos no sistema:
      <% if (user.siteRoles && user.siteRoles.length) { %>
        <strong><%= user.siteRoles.join(", ") %></strong>
      <% } else { %>
        <strong>nenhum reconhecido</strong>
      <% } %>
    </p>
  </div>
</section>

<section class="container grid">
  <div class="card stat-card">
    <h3>Farm da semana</h3>
    <p class="big">R$ <%= totalFarm.toLocaleString("pt-BR") %></p>
  </div>

  <div class="card stat-card">
    <h3>Meta semanal</h3>
    <p class="big">R$ <%= metaSemanal.toLocaleString("pt-BR") %></p>
  </div>

  <div class="card stat-card">
    <h3>Falta bater</h3>
    <p class="big">R$ <%= falta.toLocaleString("pt-BR") %></p>
  </div>
</section>

<section class="container grid">
  <div class="card stat-card">
    <h3>Status da meta</h3>
    <p class="big"><%= statusMeta === "batida" ? "✅ Batida" : "⏳ Pendente" %></p>
  </div>

  <div class="card stat-card">
    <h3>Família recebe</h3>
    <p class="big">R$ <%= resumoMeta.valorFamilia.toLocaleString("pt-BR") %></p>
  </div>

  <div class="card stat-card">
    <h3>Limpo estimado</h3>
    <p class="big">R$ <%= resumoMeta.valorLimpo.toLocaleString("pt-BR") %></p>
  </div>
</section>

<section class="container grid">
  <div class="card">
    <h3>Progresso</h3>
    <div class="progress-wrap">
      <div class="progress-bar">
        <div class="progress-fill" style="width: <%= percentual %>%"></div>
      </div>
      <p><strong><%= percentual.toFixed(1) %>%</strong> concluído</p>
    </div>
  </div>

  <div class="card">
    <h3>Resumo da meta</h3>
    <p><strong>Excedente:</strong> R$ <%= resumoMeta.excedente.toLocaleString("pt-BR") %></p>
    <p><strong>Faltante:</strong> R$ <%= resumoMeta.faltante.toLocaleString("pt-BR") %></p>
    <p><strong>Registros:</strong> <%= meusRegistros.length %></p>
  </div>

  <div class="card">
    <h3>Semana RP</h3>
    <p><strong>Início:</strong> <%= new Date(semana.inicio).toLocaleString("pt-BR") %></p>
    <p><strong>Fim:</strong> <%= new Date(semana.fim).toLocaleString("pt-BR") %></p>
  </div>
</section>

<section class="container card">
  <h2>Meus registros de farm</h2>

  <% if (!meusRegistros.length) { %>
    <p>Nenhum registro de farm nesta semana.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Valor</th>
          <th>Cargo</th>
          <th>Origem</th>
          <th>Obs.</th>
          <th>Comprovante</th>
          <th>Data</th>
        </tr>
      </thead>
      <tbody>
        <% meusRegistros.forEach(item => { %>
          <tr>
            <td>R$ <%= Number(item.valor || 0).toLocaleString("pt-BR") %></td>
            <td><%= item.cargo %></td>
            <td><%= item.origem %></td>
            <td><%= item.observacao || "-" %></td>
            <td>
              <% if (item.comprovante) { %>
                <a href="<%= item.comprovante %>" target="_blank" rel="noopener noreferrer">Ver</a>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= new Date(item.registradoEm).toLocaleString("pt-BR") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include("partials/footer") %>
