<%- include("partials/header") %>

<section class="container hero-panel">
  <div class="hero-panel-card">
    <div>
      <p class="eyebrow">PAINEL DA LIDERANÇA</p>
      <h1>Painel da Liderança</h1>
      <p class="muted">
        Semana atual:
        <strong><%= new Date(semana.inicio).toLocaleString("pt-BR") %></strong>
        até
        <strong><%= new Date(semana.fim).toLocaleString("pt-BR") %></strong>
      </p>
    </div>

    <div class="hero-summary-mini">
      <div>
        <span>Farm total</span>
        <strong>R$ <%= resumoFarm.totalFarm.toLocaleString("pt-BR") %></strong>
      </div>
      <div>
        <span>Membros ativos</span>
        <strong><%= resumoFarm.membrosAtivos %></strong>
      </div>
    </div>
  </div>
</section>

<section class="container grid grid-5">
  <div class="card stat-card">
    <p class="stat-label">Farm da semana</p>
    <p class="big">R$ <%= resumoFarm.totalFarm.toLocaleString("pt-BR") %></p>
    <p class="muted">Somatório de todos</p>
  </div>

  <div class="card stat-card">
    <p class="stat-label">Registros</p>
    <p class="big"><%= resumoFarm.totalRegistros %></p>
    <p class="muted">Entradas de farm</p>
  </div>

  <div class="card stat-card">
    <p class="stat-label">Bateram meta</p>
    <p class="big"><%= resumoFarm.bateramMeta %></p>
    <p class="muted">Membros em dia</p>
  </div>

  <div class="card stat-card">
    <p class="stat-label">Pendentes</p>
    <p class="big"><%= resumoFarm.pendentes %></p>
    <p class="muted">Ainda faltando meta</p>
  </div>

  <div class="card stat-card">
    <p class="stat-label">Itens no baú</p>
    <p class="big"><%= resumoEstoque.totalQuantidade %></p>
    <p class="muted"><%= resumoEstoque.totalItens %> tipos cadastrados</p>
  </div>
</section>

<section class="container two-columns">
  <div class="card">
    <div class="card-header">
      <h2>Ranking semanal de farm</h2>
      <span class="tag"><%= ranking.length %> membros</span>
    </div>

    <% if (!ranking.length) { %>
      <p class="muted">Nenhum farm registrado ainda nesta semana.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Membro</th>
            <th>Cargo</th>
            <th>Total</th>
            <th>Meta</th>
            <th>%</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% ranking.forEach(item => { %>
            <tr>
              <td>
                <strong><%= item.username %></strong><br>
                <small><%= item.registros %> registros</small>
              </td>
              <td><%= item.cargo %></td>
              <td>R$ <%= item.total.toLocaleString("pt-BR") %></td>
              <td>R$ <%= item.meta.toLocaleString("pt-BR") %></td>
              <td><%= item.percentual.toFixed(1) %>%</td>
              <td>
                <span class="status-pill status-<%= item.status %>">
                  <% if (item.status === "batida") { %>Bateu<% } %>
                  <% if (item.status === "quase") { %>Quase<% } %>
                  <% if (item.status === "pendente") { %>Pendente<% } %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Pendentes da semana</h2>
      <span class="tag tag-warning"><%= pendentes.length %> pendentes</span>
    </div>

    <% if (!pendentes.length) { %>
      <p class="muted">Todos que registraram já bateram meta.</p>
    <% } else { %>
      <div class="ranking-list">
        <% pendentes.forEach(item => { %>
          <div class="ranking-item">
            <div class="ranking-left">
              <div>
                <strong><%= item.username %></strong>
                <p><%= item.cargo %></p>
              </div>
            </div>
            <div class="ranking-right">
              <strong>Falta R$ <%= item.falta.toLocaleString("pt-BR") %></strong>
              <small><%= item.percentual.toFixed(1) %>% da meta</small>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="container two-columns">
  <div class="card">
    <div class="card-header">
      <h2>Resumo do estoque</h2>
      <span class="tag">Baú</span>
    </div>

    <% if (!estoque.length) { %>
      <p class="muted">Sem itens no estoque.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Tipo</th>
            <th>Quantidade</th>
          </tr>
        </thead>
        <tbody>
          <% estoque.forEach(item => { %>
            <tr>
              <td><%= item.item %></td>
              <td><%= item.tipo %></td>
              <td><%= item.quantidade %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Top itens do baú</h2>
      <span class="tag">Maior quantidade</span>
    </div>

    <% if (!topItens.length) { %>
      <p class="muted">Sem itens para mostrar.</p>
    <% } else { %>
      <div class="ranking-list">
        <% topItens.forEach((item, index) => { %>
          <div class="ranking-item">
            <div class="ranking-left">
              <span class="ranking-position"><%= index + 1 %></span>
              <div>
                <strong><%= item.item %></strong>
                <p><%= item.tipo %></p>
              </div>
            </div>
            <div class="ranking-right">
              <strong><%= item.quantidade %></strong>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<section class="container two-columns">
  <div class="card">
    <div class="card-header">
      <h2>Últimos farms registrados</h2>
      <span class="tag">Recentes</span>
    </div>

    <% if (!ultimosFarms.length) { %>
      <p class="muted">Nenhum farm registrado.</p>
    <% } else { %>
      <div class="activity-list">
        <% ultimosFarms.forEach(item => { %>
          <div class="activity-item">
            <div>
              <strong><%= item.username %></strong>
              <p>
                R$ <%= Number(item.valor || 0).toLocaleString("pt-BR") %>
                · <%= item.cargo %>
                · <%= item.origem || "bot" %>
              </p>
            </div>
            <small><%= new Date(item.registradoEm).toLocaleString("pt-BR") %></small>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Últimas movimentações do baú</h2>
      <span class="tag">Logs</span>
    </div>

    <% if (!movimentacoes.length) { %>
      <p class="muted">Nenhuma movimentação encontrada.</p>
    <% } else { %>
      <div class="activity-list">
        <% movimentacoes.forEach(item => { %>
          <div class="activity-item">
            <div>
              <strong><%= item.username %></strong>
              <p>
                <span class="tag small-tag"><%= item.acao %></span>
                <%= item.item %> · <%= item.quantidade %> · <%= item.tipo %>
              </p>
            </div>
            <small><%= new Date(item.createdAt).toLocaleString("pt-BR") %></small>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>