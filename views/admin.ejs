<%- include("partials/header") %>

<section class="container card">
  <h1>Painel da Liderança</h1>
  <p>
    Semana atual:
    <strong><%= new Date(semana.inicio).toLocaleString("pt-BR") %></strong>
    até
    <strong><%= new Date(semana.fim).toLocaleString("pt-BR") %></strong>
  </p>
</section>

<section class="container card">
  <h2>Ranking semanal de farm</h2>

  <% if (!ranking.length) { %>
    <p>Nenhum farm registrado ainda nesta semana.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Membro</th>
          <th>Cargo</th>
          <th>Total</th>
          <th>Meta</th>
          <th>Falta</th>
          <th>%</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% ranking.forEach(item => { %>
          <tr>
            <td><%= item.username %></td>
            <td><%= item.cargo %></td>
            <td>R$ <%= item.total.toLocaleString("pt-BR") %></td>
            <td>R$ <%= item.meta.toLocaleString("pt-BR") %></td>
            <td>R$ <%= item.falta.toLocaleString("pt-BR") %></td>
            <td><%= item.percentual.toFixed(1) %>%</td>
            <td><%= item.status %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<section class="container grid">
  <div class="card">
    <h2>Estoque atual</h2>

    <% if (!estoque.length) { %>
      <p>Sem itens no estoque.</p>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Tipo</th>
            <th>Quantidade</th>
          </tr>
        </thead>
        <tbody>
          <% estoque.forEach(item => { %>
            <tr>
              <td><%= item.item %></td>
              <td><%= item.tipo %></td>
              <td><%= item.quantidade %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</section>

<section class="container card">
  <h2>Últimas movimentações do baú</h2>

  <% if (!movimentacoes.length) { %>
    <p>Nenhuma movimentação encontrada.</p>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Usuário</th>
          <th>Ação</th>
          <th>Item</th>
          <th>Qtd</th>
          <th>Tipo</th>
          <th>Data</th>
        </tr>
      </thead>
      <tbody>
        <% movimentacoes.forEach(item => { %>
          <tr>
            <td><%= item.username %></td>
            <td><%= item.acao %></td>
            <td><%= item.item %></td>
            <td><%= item.quantidade %></td>
            <td><%= item.tipo %></td>
            <td><%= new Date(item.createdAt).toLocaleString("pt-BR") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<%- include("partials/footer") %>